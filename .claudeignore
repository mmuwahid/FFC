# .claudeignore — excludes paths from Claude Code's Glob/Grep/Read tool surface.
# Different from .gitignore (which controls git tracking). This controls what
# Claude sees when exploring the repo — keeps tool output clean, avoids
# accidental token spend reading huge or irrelevant files.

# ── Dependencies ──
node_modules/
.pnpm-store/
ffc/node_modules/

# ── Build artifacts ──
dist/
build/
.next/
out/
.vite/
.turbo/
ffc/dist/
ffc/.vite/

# ── Lock files (large, almost never edited by hand) ──
package-lock.json
ffc/package-lock.json
yarn.lock
pnpm-lock.yaml

# ── Vercel + Supabase generated ──
.vercel/
supabase/.temp/
supabase/.branches/

# ── Stale worktrees + Claude Code internals ──
.claude/worktrees/
.claude/cache/
.superpowers/
.playwright-cli/

# ── Generated TypeScript types (regenerable via `supabase gen types`) ──
ffc/src/lib/database.types.ts

# ── Binary assets and large media ──
*.docx
*.xlsx
*.pdf
*.png
*.jpg
*.jpeg
*.webp
*.gif
*.ico
*.woff
*.woff2
*.ttf
docs/brief-screenshots/

# ── Archived history — kept on disk, hidden from tool surface ──
tasks/_archive/
sessions/_archive/

# ── Scratch + archived history (catches old masterplans, shipped specs/plans) ──
_wip/
archive/
